{
  "family": "clothco-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::416069842338:role/ecsTaskExecutionRole",
  "taskRoleArn":      "arn:aws:iam::416069842338:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "clothco-app",
      "image": "416069842338.dkr.ecr.eu-north-1.amazonaws.com/clothingcompany-api:latest",
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",      "value": "production" },
        { "name": "PORT",          "value": "3000" },
        { "name": "JWT_EXPIRES_IN","value": "7d" }
      ],
      "secrets": [
        {
          "name": "MONGO_URI",
          "valueFrom": "arn:aws:ssm:eu-north-1:416069842338:parameter/clothco/MONGO_URI"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:ssm:eu-north-1:416069842338:parameter/clothco/JWT_SECRET"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/clothco",
          "awslogs-region":        "eu-north-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group":  "true"
        }
      },
      "essential": true,
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3000/api/v1/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
